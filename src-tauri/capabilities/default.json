{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Only the Atlas Registry main window may invoke the audited application command surface",
  "windows": ["main"],
  "permissions": [
    "allow-registry-capabilities",
    "allow-export-diagnostic-bundle",
    "allow-probe-connection",
    "allow-load-connection-profiles",
    "allow-upsert-connection-profile",
    "allow-delete-connection-profile",
    "allow-open-connection",
    "allow-close-connection",
    "allow-list-resources",
    "allow-read-resource",
    "allow-search-resources",
    "allow-list-resource-history",
    "allow-read-resource-history",
    "allow-inspect-native-resource",
    "allow-mutate-resource",
    "allow-execute-etcd-transaction",
    "allow-execute-etcd-lease-action",
    "allow-execute-zookeeper-native-action",
    "allow-list-nacos-namespaces",
    "allow-list-nacos-services",
    "allow-read-nacos-service",
    "allow-list-nacos-instances",
    "allow-execute-nacos-native-action",
    "allow-export-resource",
    "allow-choose-import",
    "allow-apply-import",
    "allow-load-audit-history",
    "allow-cancel-operation",
    "allow-start-watch",
    "allow-stop-watch",
    "allow-check-for-app-update",
    "allow-install-app-update"
  ]
}
