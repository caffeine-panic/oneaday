{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas Registry",
  "version": "0.4.0",
  "identifier": "dev.oneaday.atlas-registry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Atlas Registry", "width": 1280, "height": 800, "minWidth": 900, "minHeight": 620 }],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-src 'none'; form-action 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0NTJDOTVDNDcyQ0UzQzgKUldUSTR5eEhYTWxTWkMrUEpKSS9IOVBLOElpTGJ2aElpRW8zZUk5NDdvVVVEMzcxQUk5T2RzVEkK",
      "endpoints": [
        "https://github.com/caffeine-panic/oneaday/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
