{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas Registry",
  "version": "0.1.0",
  "identifier": "dev.oneaday.atlas-registry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Atlas Registry", "width": 1280, "height": 800, "minWidth": 900, "minHeight": 620 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
